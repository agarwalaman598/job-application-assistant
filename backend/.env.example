# ── Database ──────────────────────────────────────────
# NeonDB (PostgreSQL) connection string
DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth ──────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# ── LLM API (Groq / OpenAI / compatible) ──────────────
LLM_API_KEY=your-groq-or-openai-api-key
LLM_API_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-8b-8192

# ── Cloudflare R2 Storage ─────────────────────────────
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=job-assist-ai
R2_REGION=auto

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=JobAssist AI

# ── App URLs ──────────────────────────────────────────
# Frontend URL for email links (verification, password reset)
APP_BASE_URL=https://your-frontend.vercel.app
# Comma-separated frontend origins for CORS
FRONTEND_URL=https://your-frontend.vercel.app

# ── Environment ───────────────────────────────────────
APP_ENV=production
