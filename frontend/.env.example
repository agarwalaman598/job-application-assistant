# Frontend environment variables
# Copy this file to .env and fill in values for your environment.

# Full URL to the backend API (including /api path segment).
# Leave unset for same-domain deployments (nginx / Docker Compose).
# Set for cross-origin deployments, e.g. Vercel frontend + Railway backend:
#   VITE_API_URL=https://your-backend.up.railway.app/api
VITE_API_URL=
